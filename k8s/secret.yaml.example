# Copy this file to secret.yaml, fill in your values, then apply it.
# All values are plain-text (stringData); Kubernetes will base64-encode them.
# Leave a key empty ("") if you don't use that service.
apiVersion: v1
kind: Secret
metadata:
  name: shadowbroker-env
  namespace: shadowbroker
type: Opaque
stringData:
  AIS_API_KEY: ""
  OPENSKY_CLIENT_ID: ""
  OPENSKY_CLIENT_SECRET: ""
  LTA_ACCOUNT_KEY: ""
  ADMIN_KEY: ""
  FINNHUB_API_KEY: ""
  MESH_PEER_PUSH_SECRET: ""
